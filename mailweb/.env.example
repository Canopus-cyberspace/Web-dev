# Flask / Waitress
APP_HOST=127.0.0.1
APP_PORT=5000
LOG_LEVEL=INFO

# 公网场景建议把收件人固定为老师邮箱，避免被滥用为任意转发器。
MAIL_TO_EMAIL=teacher@example.com

# SMTP 基本配置
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_TIMEOUT=10

# 可选：若 SMTP 服务要求固定发件地址，建议填写。
# 例如认证 SMTP 常见做法是设置为你的企业邮箱或系统邮箱。
# 如果留空，程序会默认使用表单中的 email 作为发件地址。
SMTP_FROM_EMAIL=
