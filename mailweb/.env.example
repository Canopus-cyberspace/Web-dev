# Flask / Waitress
APP_HOST=127.0.0.1
APP_PORT=5000
LOG_LEVEL=INFO

# 推荐优先使用外部 SMTP 中继，例如 587 + AUTH + STARTTLS。
# 发给 QQ 邮箱时，MAIL_FROM 尽量与 SMTP 账号所属域一致，发信域最好能通过 SPF 或 DKIM。
# 不再默认推荐 127.0.0.1:25 本机直发，只有在你明确知道上游 MTA 配置时才建议这样做。
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your_account
SMTP_PASSWORD=your_password_or_app_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM=your_account@your-domain.com
MAIL_FROM_NAME=Mail Web
MAIL_REPLY_TO=your_account@your-domain.com
MAIL_TIMEOUT=15